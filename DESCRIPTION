Package: mtaOpenData
Type: Package
Title: Convenient Access to MTA Open Data API Endpoints
Version: 0.1.0
Authors@R: 
    c(
      person("Christian", "Martinez", 
             email = "c.martinez0@outlook.com", 
             role = c("aut", "cre"),
             comment = c(
               GitHub = "martinezc1",
               ORCID = "0009-0005-6026-6454"
             ))
